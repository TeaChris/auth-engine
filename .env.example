# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://admin:admin123@localhost:5432/auth_db?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT (generate with: openssl rand -hex 64) ────────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_use_openssl_rand_hex_64"
JWT_REFRESH_SECRET="CHANGE_ME_use_a_different_openssl_rand_hex_64"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── CSRF (generate with: openssl rand -hex 64) ───────────────────────────────
# MUST be different from JWT secrets!
CSRF_SECRET="CHANGE_ME_use_yet_another_openssl_rand_hex_64"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=100             # general requests per window
AUTH_RATE_LIMIT_MAX=10         # auth endpoint requests per window

# ─── Account Lockout ──────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5           # failed logins before account lock
ACCOUNT_LOCKOUT_MINUTES=15     # how long the lock lasts

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# For development, use Ethereal (https://ethereal.email) for a free test inbox.
# For production, replace with your provider (SES, SendGrid SMTP relay, etc.)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_password
SMTP_FROM="Auth System <no-reply@example.com>"

# ─── Cluster ──────────────────────────────────────────────────────────────────
# Set to true to use Node.js built-in cluster module.
# Leave false when using PM2 (PM2 handles clustering via ecosystem.config.js).
CLUSTER_ENABLED=false
